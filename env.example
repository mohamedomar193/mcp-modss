# Copy this file to .env (in the same folder) and fill in your values.
# Do not commit .env.

# PostgreSQL password (used by docker-compose for both the postgres container and app services).
# In Docker, DATABASE_URL is built automatically from this in docker-compose.yml.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# For local development (without Docker), set DATABASE_URL directly instead:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/mcp_tasks

# Secret for POST /ingest (X-Ingest-Token header). Required.
INGEST_TOKEN=change-me-to-a-long-random-secret

# OpenAI API key for LLM-powered task enhancement (GPT-5 mini + RAG).
# Get one at https://platform.openai.com/api-keys
# If empty, tasks are returned without LLM enhancement.
OPENAI_API_KEY=sk-...

# Jira integration (for report_failed_test MCP tool)
JIRA_BASE_URL=https://billqode.atlassian.net
JIRA_PROJECT_KEY=BILQ
JIRA_EMAIL=your-jira-email@example.com
JIRA_API_TOKEN=your-jira-api-token
