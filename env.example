# Copy this file to .env (in the same folder) and fill in your values.
# Do not commit .env.

# PostgreSQL connection (required for MCP server and ingest server)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/mcp_tasks

# Optional: secret for POST /ingest (X-Ingest-Token header). Leave empty to disable token check.
INGEST_TOKEN=

# Optional: OpenAI API key for LLM-powered task enhancement (GPT-5 mini).
# Get one at https://platform.openai.com/api-keys
# If empty, tasks are stored as-is without LLM enhancement.
OPENAI_API_KEY=
